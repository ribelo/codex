{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "FsReadDirectoryEntry": {
      "description": "A directory entry returned by `fs/readDirectory`.",
      "properties": {
        "fileName": {
          "description": "Direct child entry name only, not an absolute or relative path.",
          "type": "string"
        },
        "isDirectory": {
          "type": "boolean"
        },
        "isFile": {
          "type": "boolean"
        }
      },
      "required": [
        "fileName",
        "isDirectory",
        "isFile"
      ],
      "type": "object"
    }
  },
  "description": "Successful response for `fs/readDirectory`.",
  "properties": {
    "entries": {
      "items": {
        "$ref": "#/definitions/FsReadDirectoryEntry"
      },
      "type": "array"
    }
  },
  "required": [
    "entries"
  ],
  "title": "FsReadDirectoryResponse",
  "type": "object"
}